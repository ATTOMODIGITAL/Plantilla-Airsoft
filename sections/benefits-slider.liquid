{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'benefits-slider.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    <div class="slider-mobile-gutter">
      <ul class="benefits-slider" role="list">
        {%- for block in section.blocks -%}
          <li class="benefits-item" {{ block.shopify_attributes }}>
            <div
              class="benefits-card"
              style="background-color: {{ block.settings.background_color_card }};"
            >
              <div
                class="benefits-card__icon"
                style="background-color: {{ block.settings.background_color_icon }}; color: {{ block.settings.icon_color }};"
              >
                {%- if block.settings.icon != 'none' -%}
                  {%- render 'icon', icon: block.settings.icon -%}
                {%- endif -%}
              </div>
              <div class="benefits-card__content">
                <p class="benefits-card__title" style="color: {{ block.settings.icon_color }};">
                  {{ block.settings.title }}
                </p>
                <p class="benefits-card__text" style="color: {{ block.settings.icon_color }};">
                  {{ block.settings.text }}
                </p>
              </div>
            </div>
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Barra de beneficios",
  "tag": "section",
  "class": "section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme-1",
      "label": "Esquema de color"
    },
    {
      "type": "header",
      "content": "Espaciado"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding superior",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding inferior",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Beneficio",
      "settings": [
        {
          "type": "header",
          "content": "Estilo de Tarjeta"
        },
        {
          "type": "color",
          "id": "background_color_card",
          "label": "Fondo de la tarjeta",
          "default": "#ffffff"
        },
        {
          "type": "color",
          "id": "background_color_icon",
          "label": "Fondo del círculo del icono",
          "default": "#7ED957"
        },
        {
          "type": "color",
          "id": "icon_color",
          "label": "Color del icono (SVG)",
          "default": "#000000"
        },
        {
          "type": "select",
          "id": "icon",
          "options": [
            { "value": "none", "label": "Ninguno" },
            { "value": "star", "label": "Estrella" },
            { "value": "truck", "label": "Camión" },
            { "value": "lock", "label": "Candado" },
            { "value": "return", "label": "Devolución" }
          ],
          "default": "truck",
          "label": "Icono"
        },
        {
          "type": "inline_richtext",
          "id": "title",
          "label": "Título",
          "default": "Envío rápido"
        },
        {
          "type": "inline_richtext",
          "id": "text",
          "label": "Texto",
          "default": "Recibe tu pedido en 24/48h"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Barra de beneficios fluida",
      "blocks": [{ "type": "benefit" }, { "type": "benefit" }, { "type": "benefit" }, { "type": "benefit" }]
    }
  ]
}
{% endschema %}
