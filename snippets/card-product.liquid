{% comment %}
  Nueva tarjeta de producto simplificada
  Uso: {% render 'n-card-product', card_product: product %}
{% endcomment %}

{%- if card_product and card_product != empty -%}
  <a href="{{ card_product.url }}" class="n-card-container">
    {%- if card_product.available == false -%}
      <span class="n-card-badge">{{ 'products.product.sold_out' | t }}</span>
    {%- elsif card_product.compare_at_price > card_product.price -%}
      <span class="n-card-badge sale">{{ 'products.product.on_sale' | t }}</span>
    {%- endif -%}

    <div class="n-card-media">
      {%- if card_product.featured_media -%}
        <img
          src="{{ card_product.featured_media | image_url: width: 640 }}"
          alt="{{ card_product.featured_media.alt | escape }}"
          loading="lazy"
          class="n-card-img-primary"
        >
        {%- if card_product.media[1] != null and show_secondary_image -%}
          <img
            src="{{ card_product.media[1] | image_url: width: 640 }}"
            alt="{{ card_product.media[1].alt | escape }}"
            loading="lazy"
            class="n-card-img-secondary"
          >
        {%- endif -%}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>

    <div class="n-card-info">
      <div>
        {%- if show_vendor -%}
          <span class="n-card-vendor">{{ card_product.vendor }}</span>
        {%- endif -%}
        <h3 class="n-card-title">{{ card_product.title | escape }}</h3>
      </div>

      <div class="n-card-details">
        <div class="n-card-price">
          {%- if card_product.compare_at_price > card_product.price -%}
            <span style="text-decoration: line-through; color: #999; font-size: 0.8em;">
              {{ card_product.compare_at_price | money }}
            </span>
          {%- endif -%}
          <span>{{ card_product.price | money }}</span>
        </div>

        {%- if quick_add -%}
          {% comment %} Aquí iría un botón minimalista de compra si lo necesitas {% endcomment %}
        {%- endif -%}
      </div>
    </div>
  </a>
{%- endif -%}
